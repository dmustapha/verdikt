# Stellar Testnet Keypairs (generate with: stellar keys generate <name> --network testnet)
ESCROW_SECRET=S...
ESCROW_PUBLIC=G...
BUYER_SECRET=S...
BUYER_PUBLIC=G...
SELLER_SECRET=S...
SELLER_PUBLIC=G...

# Soroban Contract IDs (deployed by scripts/deploy-contracts.sh)
EVIDENCE_REGISTRY_ID=C...
DISPUTE_RESOLUTION_ID=C...
TRUST_LEDGER_ID=C...

# OZ Facilitator (get key from: https://channels.openzeppelin.com/testnet/gen)
OZ_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
OZ_API_KEY=

# Anthropic (for Judge Agent narration)
ANTHROPIC_API_KEY=

# Network (defaults)
SOROBAN_RPC=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Server
PORT=4000
